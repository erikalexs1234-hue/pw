<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Login Vanilla JS</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="login-container">
        <h2>Login Form</h2>
        
        <div class="input-group">
            <label>Username:</label>
            <input type="text" id="username" placeholder="Masukkan username">
        </div>

        <div class="input-group">
            <label>Password:</label>
            <input type="password" id="password" placeholder="Masukkan password">
        </div>

        <div class="button-group">
            <button id="btnLogin">Login</button>
            <button id="btnCancel">Cancel</button>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>

body {
    font-family: Arial, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background-color: #f0f2f5;
    margin: 0;
}

.login-container {
    background: white;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    width: 300px;
}

.input-group {
    margin-bottom: 15px;
}

.input-group input {
    width: 100%;
    padding: 8px;
    box-sizing: border-box; /* Agar padding tidak merusak lebar */
}

.button-group {
    display: flex;
    gap: 10px;
}

button {
    flex: 1;
    padding: 10px;
    cursor: pointer;
}

#btnLogin { background-color: #28a745; color: white; border: none; }
#btnCancel { background-color: #dc3545; color: white; border: none; }

/ 1. DOM Selector (Mengambil elemen berdasarkan ID)
const inputUser = document.getElementById('username');
const inputPass = document.getElementById('password');
const btnLogin = document.getElementById('btnLogin');
const btnCancel = document.getElementById('btnCancel');

// 2. Event Listener (Menjalankan fungsi saat tombol diklik)
btnLogin.addEventListener('click', function() {
    const user = inputUser.value;
    const pass = inputPass.value;

    if (user === "admin" && pass === "123") {
        alert("Login Berhasil! Selamat datang " + user);
    } else {
        alert("Username atau Password salah.");
    }
});

btnCancel.addEventListener('click', function() {
    // Mengosongkan kembali input
    inputUser.value = "";
    inputPass.value = "";
    console.log("Input telah dibersihkan.");
});
